{
  "$schema": "http://json.schemastore.org/template",
  "author": "NETWORG",
  "identity": "TALXIS.DevKit.Templates.Dataverse.CodeApp",
  "name": "Power Platform: Code App",
  "shortName": "pp-app-code",
  "classifications": ["Dataverse", "Power Platform"],
  "sourceName": "CodeAppExample",
  "tags": {
		"language": "XML"
	},
  "preferNameDirectory": true,
  "symbols": {
    "DisplayName": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "appexampleDisplayName"
    },
    "EnvironmentId": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "envexampleid"
    },
    "AppId": {
      "type": "generated",
			"generator": "guid",
			"replaces": "appexampleId",
			"parameters": {
				"defaultFormat": "d"
			}
		}
  },
  "postActions": [
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/AppInit.ps1\""
      }
    },
    {
			"actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
			"args": {
				"executable": "pwsh",
				"args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/Cleanup.ps1\"",
				"redirectStandardOutput": "false"
			},
			"manualInstructions": [{ "text": "Removing Scripts" }],
			"continueOnError": false,
			"description": "Removing Scripts"
		}
  ]
}