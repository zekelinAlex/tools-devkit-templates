{
  "$schema": "http://json.schemastore.org/template",
  "author": "NETWORG",
  "identity": "TALXIS.DevKit.Templates.Dataverse.BusinessProcessFlows.Stage",
  "name": "Power Platform: BPF Stage",
  "shortName": "pp-bpf-stage",
  "description": "Adds a stage to an existing BPF: stage.xaml (StageComposite XAML) + stageForm.xml (tab with columns/sections) + steplabels.xml. Run inside the BPF project created by pp-bpf.",
  "tags": {
    "language": "XML",
    "type": "item"
  },
  "sourceName": "SolutionLogicalNameExample",
  "sources": [
    {
      "exclude": [
        "**/[Bb]in/**",
        "**/[Oo]bj/**",
        "*/**/[Bb]in/**",
        "*/**/[Oo]bj/**",
        "**/**/[Bb]in/**",
        "**/**/[Oo]bj/**",
        ".template.config/**/*"
      ]
    }
  ],
  "preferNameDirectory": true,
  "symbols": {
    "SolutionRootPath": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": ".",
      "replaces": "SolutionDeclarationsRoot",
      "fileRename": "SolutionDeclarationsRoot",
      "description": "Folder under the project folder where solution components will be placed. Use '.' to place directly in the project folder."
    },
    "FormId": {
      "type": "parameter",
      "generator": "text",
      "replaces": "mainFormIdexample",
      "fileRename": "mainFormIdexample",
      "description": "GUID of the BPF main form. Obtain from the form XML file generated by pp-bpf."
    },
    "BPFLogicalName": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "examplebpfname",
      "fileRename": "examplebpfname",
      "isRequired": true,
      "description": "Logical name of the BPF (without publisher prefix) that this stage belongs to."
    },
    "PrimaryEntity": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "primaryentityexample",
      "fileRename": "primaryentityexample",
      "description": "Logical name of the primary entity the BPF runs on (Example: lead, opportunity)."
    },
    "StageName": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "stageexamplename",
      "fileRename": "stageexamplename",
      "description": "Display name for this stage shown in the BPF UI (Example: Qualify, Develop, Close)."
    },
    "StageId": {
      "type": "generated",
      "generator": "guid",
      "replaces": "stageexampleid",
      "fileRename": "stageexampleid",
      "parameters": {
        "defaultFormat": "d"
      }
    },
    "1mainId": {
      "type": "generated",
      "generator": "guid",
      "replaces": "1mainId",
      "fileRename": "1mainId",
      "parameters": {
        "defaultFormat": "d"
      }
    },
    "2mainId": {
      "type": "generated",
      "generator": "guid",
      "replaces": "2mainId",
      "fileRename": "2mainId",
      "parameters": {
        "defaultFormat": "d"
      }
    },
    "3mainId": {
      "type": "generated",
      "generator": "guid",
      "replaces": "3mainId",
      "fileRename": "3mainId",
      "parameters": {
        "defaultFormat": "d"
      }
    },
    "isThisaLastStage": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "true",
      "description": "Set to true if this is the final stage of the BPF. Affects how the finish button is generated in the XAML workflow (default: true)."
    }
  },
  "primaryOutputs": [
    {
      "path": "SolutionLogicalNameExample.csproj"
    }
  ],
  "postActions": [
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/NextStage.ps1\"",
        "redirectStandardOutput": "false"
      }
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/AddToXaml.ps1\"",
        "redirectStandardOutput": "false"
      }
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/AddToForm.ps1\"",
        "redirectStandardOutput": "false"
      }
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/steplabels.ps1\"",
        "redirectStandardOutput": "false"
      }
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/Cleanup.ps1\"",
        "redirectStandardOutput": "false"
      },
      "manualInstructions": [
        {
          "text": "Removing template files"
        }
      ],
      "continueOnError": false,
      "description": "Removing template files"
    }
  ]
}