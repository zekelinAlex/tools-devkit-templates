{
  "$schema": "http://json.schemastore.org/template",
  "author": "NETWORG",
  "identity": "TALXIS.DevKit.Templates.Dataverse.BusinessProcessFlows",
  "name": "Power Platform: Business Process Flow",
  "shortName": "pp-bpf",
  "description": "Scaffolds a Business Process Flow: Entity.xml (BPF entity with ActiveStageId, Duration etc.) + main form + RibbonDiff.xml + relationship to primary entity + XAML workflow. Add stages with pp-bpf-stage, steps with pp-bpf-stage-step.",
  "tags": {
    "language": "XML",
    "type": "item"
  },
  "sourceName": "SolutionLogicalNameExample",
  "sources": [
    {
      "exclude": [
        "**/[Bb]in/**",
        "**/[Oo]bj/**",
        "*/**/[Bb]in/**",
        "*/**/[Oo]bj/**",
        "**/**/[Bb]in/**",
        "**/**/[Oo]bj/**",
        ".template.config/**/*"
      ]
    }
  ],
  "preferNameDirectory": true,
  "symbols": {
    "SolutionRootPath": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": ".",
      "replaces": "SolutionDeclarationsRoot",
      "fileRename": "SolutionDeclarationsRoot",
      "description": "Folder under the project folder where solution components will be placed. Use '.' to place directly in the project folder."
    },
    "PublisherPrefix": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "examplepublisher",
      "fileRename": "examplepublisher",
      "isRequired": true,
      "description": "Publisher prefix as defined in Other/Solution.xml of the solution. Used in entity and component names (Example: talxis)."
    },
    "FormId": {
      "type": "generated",
      "generator": "guid",
      "replaces": "mainFormIdexample",
      "fileRename": "mainFormIdexample",
      "parameters": {
        "defaultFormat": "d"
      }
    },
    "BPFName": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "examplebpfname",
      "fileRename": "examplebpfname",
      "isRequired": true,
      "description": "Logical name of the BPF (without publisher prefix). Used as the entity name and XAML workflow name."
    },
    "PrimaryEntity": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "primaryentityexample",
      "fileRename": "primaryentityexample",
      "description": "Logical name of the primary entity that this BPF runs on (Example: lead, opportunity)."
    }
  },
  "primaryOutputs": [
    {
      "path": "SolutionLogicalNameExample.csproj"
    }
  ],
  "postActions": [
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/GenerateWorkflowId.ps1\"",
        "redirectStandardOutput": "false"
      }
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/AddRelationshipsl.ps1\"",
        "redirectStandardOutput": "false"
      }
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/AddToSolutionXml.ps1\"",
        "redirectStandardOutput": "false"
      }
    },
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/Cleanup.ps1\"",
        "redirectStandardOutput": "false"
      },
      "manualInstructions": [
        {
          "text": "Removing template files"
        }
      ],
      "continueOnError": false,
      "description": "Removing template files"
    }
  ]
}