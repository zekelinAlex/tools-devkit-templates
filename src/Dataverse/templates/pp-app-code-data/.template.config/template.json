{
  "$schema": "http://json.schemastore.org/template",
  "author": "NETWORG",
  "identity": "TALXIS.DevKit.Templates.Dataverse.CodeApp.Data",
  "name": "Power Platform: Code App Data",
  "shortName": "pp-app-code-data",
  "description": "Adds a typed data-access layer to an existing Code App project. Generates model classes for a specific Dataverse entity based on solution metadata.",
  "classifications": ["Dataverse", "Power Platform"],
  "sourceName": "pp-app-code-data",
  "tags": {
		"language": "XML"
	},
  "preferNameDirectory": true,
  "symbols": {
    "ModelSolutionPath": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "modelsolutionexamplepath",
      "description": "Relative path to the solution folder containing the entity definitions used to generate data access code."
    },
    "EntityLogicalName": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "entityexamplelogicalname",
      "description": "Logical name of the Dataverse entity for which data access code will be generated."
    }
  },
  "postActions": [
    {
      "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
      "args": {
        "executable": "pwsh",
        "args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/Init.ps1\""
      }
    },
    {
			"actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
			"args": {
				"executable": "pwsh",
				"args": "-noprofile -executionpolicy bypass -File \"./.template.scripts/Cleanup.ps1\"",
				"redirectStandardOutput": "false"
			},
			"manualInstructions": [{ "text": "Removing Scripts" }],
			"continueOnError": false,
			"description": "Removing Scripts"
		}
  ]
}